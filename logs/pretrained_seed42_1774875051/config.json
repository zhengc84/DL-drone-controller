{
  "model_type": "pretrained",
  "env": {
    "drone_model": "cf2x",
    "freq": 240,
    "ctrl_freq": 48,
    "episode_len_sec": 8.0,
    "nominal_mass_kg": 0.027,
    "mass_delta_range": [
      0.012,
      0.022
    ],
    "perturb_time_range": [
      2.0,
      3.0
    ],
    "drop_probability": 1.0,
    "hover_height": 1.0,
    "target_type": "hover",
    "kp_range": [
      0.1,
      20.0
    ],
    "ki_range": [
      0.0,
      10.0
    ],
    "kd_range": [
      0.0,
      10.0
    ],
    "gain_update_interval": 24,
    "error_history_len": 50,
    "include_pid_gains_in_obs": true,
    "reward_type": "iae",
    "settling_bonus": 5.0,
    "settling_tolerance": 0.05,
    "overshoot_penalty": 2.0,
    "control_effort_penalty": 0.01
  },
  "model": {
    "hidden_size": 128,
    "num_layers": 2,
    "dropout": 0.0,
    "mamba_d_state": 16,
    "mamba_d_conv": 4,
    "mamba_expand": 2,
    "action_dim": 3,
    "log_std_init": -1.0
  },
  "train": {
    "learning_rate": 0.0003,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_epsilon": 0.2,
    "entropy_coef": 0.0,
    "value_coef": 0.25,
    "max_grad_norm": 0.5,
    "normalize_rewards": true,
    "reward_clip": 10.0,
    "total_episodes": 2000,
    "steps_per_update": 2048,
    "num_epochs": 10,
    "minibatch_size": 64,
    "num_envs": 4,
    "seq_len": 50,
    "log_interval": 10,
    "save_interval": 100,
    "eval_episodes": 100,
    "log_dir": "logs",
    "seed": 42
  },
  "detector_weights": "LSTM_Tuner_weights.pth",
  "detector_type": "lstm",
  "unfreeze_at": 500
}